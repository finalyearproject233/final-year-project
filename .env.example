# STRATERA database configuration
# Copy to .env or set in the environment before starting the app.

# Engine: sqlite (default, local file) | postgresql | mssql
STRATERA_DB_TYPE=sqlite

# --- PostgreSQL / SQL Server (when STRATERA_DB_TYPE is postgresql or mssql) ---
# STRATERA_DB_HOST=localhost
# STRATERA_DB_PORT=5432
# STRATERA_DB_NAME=stratera
# STRATERA_DB_USER=stratera_app
# STRATERA_DB_PASSWORD=change-me
# STRATERA_DB_SSL=false

# --- SQL Server example ---
# STRATERA_DB_TYPE=mssql
# STRATERA_DB_HOST=localhost
# STRATERA_DB_PORT=1433
# STRATERA_DB_NAME=stratera
# STRATERA_DB_USER=sa
# STRATERA_DB_PASSWORD=change-me
# STRATERA_DB_SSL=true
